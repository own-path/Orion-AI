NODE_ENV=production
PORT=8080
BOT_PORT=3000
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
AGENT_SERVICE_URL=http://agent-service:8080
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_REQUIRED=true
GEMINI_TIMEOUT_MS=30000
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_EXECUTION_MODE=mock
ORION_LOOP_INTERVAL_MS=60000
ORION_DECISION_CONFIDENCE_THRESHOLD=0.6
ORION_DATA_DIR=/app/data
SNOWFLAKE_REQUIRED=true
SNOWFLAKE_ACCOUNT=your-account
SNOWFLAKE_USERNAME=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=ORION
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=ACCOUNTADMIN
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_LOADING_SFX_TEXT=Cinematic braam with suspenseful ambient loading tone
ELEVENLABS_LOADING_SFX_MODEL_ID=eleven_text_to_sound_v2
ELEVENLABS_LOADING_SFX_DURATION_SECONDS=4
