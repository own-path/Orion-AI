NODE_ENV=production
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4
OLLAMA_REQUIRED=true
OLLAMA_TIMEOUT_MS=30000
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_EXECUTION_MODE=mock
SOLSCAN_BASE_URL=https://pro-api.solscan.io/v2.0
SOLSCAN_API_KEY=your-solscan-api-key
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-custom-search-engine-id
SOLSCAN_REQUIRED=false
ORION_DATA_DIR=/Users/yourname/.orion
ORION_LOOP_INTERVAL_MS=60000
ORION_TASK_POLL_INTERVAL_MS=5000
ORION_DECISION_CONFIDENCE_THRESHOLD=0.6
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_LOADING_SFX_TEXT=Cinematic braam with suspenseful ambient loading tone
ELEVENLABS_LOADING_SFX_MODEL_ID=eleven_text_to_sound_v2
ELEVENLABS_LOADING_SFX_DURATION_SECONDS=4
